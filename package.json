{
  "name": "local-agent-monitor",
  "version": "6.3.0",
  "description": "Navi Cleaner v6.3.0 — Deep Architecture Overhaul, Windows Resource Embedding & Interactive Storage Ring",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:win": "pkg . --output \"Navi Cleaner-win.exe\" --targets node18-win-x64",
    "build:mac": "pkg . --output \"Navi Cleaner-mac\" --targets node18-macos-x64",
    "build:icon": "npx --yes resedit-cli --in \"Navi Cleaner-win.exe\" --out \"Navi Cleaner-win.exe\" --icon 1,public/navi.ico",
    "build": "npm run build:win && npm run build:icon && npm run build:mac"
  },
  "keywords": [
    "file-indexer",
    "process-monitor",
    "sqlite",
    "security"
  ],
  "author": "javie",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "pdf-parse": "^2.4.5",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "modules/**/*",
      "node_modules/better-sqlite3/build/Release/*.node",
      "Navi Cleaner-win.exe.manifest",
      "launcher.vbs"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64"
    ]
  }
}
