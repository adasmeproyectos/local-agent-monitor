{
  "name": "local-agent-monitor",
  "version": "5.5.0",
  "description": "Navi Cleaner v5.5 — Apple Suite Desktop Edition",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --output \"Navi Cleaner.exe\" --targets node18-win-x64"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "modules/**/*",
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "keywords": [
    "file-indexer",
    "process-monitor",
    "sqlite",
    "security"
  ],
  "author": "javie",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "pdf-parse": "^2.4.5",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
